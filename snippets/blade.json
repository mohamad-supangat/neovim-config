{
  "Content Section": {
    "body": [
      "@section('${1:name}')",
      "    $2",
      "@endsection"
    ],
    "description": "content section",
    "prefix": "b:section"
  },
  "Content Section Show": {
    "body": [
      "@section('$1')",
      "    $2",
      "@show"
    ],
    "description": "content section show",
    "prefix": "b:section-show"
  },
  "Extend layout": {
    "body": "@extends('${1:name}')",
    "description": "extends view layout",
    "prefix": "b:extends"
  },
  "For-block": {
    "body": [
      "@for (\\$i = ${1:0}; \\$i < ${2:\\$count}; \\$i++)",
      "    $3",
      "@endfor"
    ],
    "description": "@for block",
    "prefix": "b:for"
  },
  "Foreach-block": {
    "body": [
      "@foreach (${1:\\$collection} as ${2:\\$item})",
      "    $3",
      "@endforeach"
    ],
    "description": "@foreach block",
    "prefix": "b:foreach"
  },
  "Has Section": {
    "body": [
      "@hasSection ('${1:name}')",
      "    $2",
      "@else",
      "    $3",
      "@endif"
    ],
    "description": "@hasSection condition",
    "prefix": "b:has-section"
  },
  "If-block": {
    "body": [
      "@if ($1)",
      "    $2",
      "@endif"
    ],
    "description": "@if block",
    "prefix": "b:if"
  },
  "If-else-block": {
    "body": [
      "@if ($1)",
      "    $2",
      "@else",
      "    $3",
      "@endif"
    ],
    "description": "if-else block",
    "prefix": "b:if-else"
  },
  "Include view": {
    "body": "@include('${1:name}')",
    "description": "include view",
    "prefix": "b:include"
  },
  "Push stack": {
    "body": [
      "@push('${1:name}')",
      "    $2",
      "@endpush"
    ],
    "description": "@push stack",
    "prefix": "b:push"
  },
  "Stack": {
    "body": "@stack('${1:name}')",
    "description": "@stack",
    "prefix": "b:stack"
  },
  "Unless-block": {
    "body": [
      "@unless ($1)",
      "    $2",
      "@endunless"
    ],
    "description": "@unless block",
    "prefix": "b:unless"
  },
  "Yield content": {
    "body": "@yield('${1:name}')",
    "description": "yield content section",
    "prefix": "b:yield"
  },
  "alert-response::component": {
    "body": "<x-alert-response />",
    "prefix": "alert-response::component"
  },
  "auth": {
    "body": [
      "@auth",
      "    $1",
      "@endauth"
    ],
    "description": "auth",
    "prefix": "b:auth"
  },
  "aware": {
    "body": "@aware(['${1:propName}'])",
    "description": "Accessing data from a parent component (Laravel 8.64)",
    "prefix": "b:aware"
  },
  "bank:card-footer": {
    "body": [
      "<div class=\"card-footer\">",
      "                        <a href=\"{{ url('') }}\" class=\"btn btn-default\"><x-heroicon-o-chevron-left",
      "                                class=\"icon\" /> Kembali</a>",
      "",
      "                        <button type=\"submit\" class=\"btn btn-primary float-right\">",
      "                            <i class=\"fas fa-save\"></i>",
      "                            Simpan",
      "                        </button>",
      "                    </div>"
    ],
    "prefix": "bank:card-footer"
  },
  "blade comment": {
    "body": "{{-- ${1:comment} --}}",
    "description": "comment block",
    "prefix": "b:comment"
  },
  "blade echo-data": {
    "body": "{{ ${1:\\$data} }}",
    "description": "echo data",
    "prefix": "b:echo"
  },
  "blade echo-unescaped-data": {
    "body": "{!! ${1:\\$html_data} !!}",
    "description": "echo unescaped data (allow html outputs)",
    "prefix": "b:echo-html"
  },
  "blade echo-untouch": {
    "body": "@{{ ${1:variable} }}",
    "description": "echo untouched data (allow javascript expression)",
    "prefix": "b:echo-raw"
  },
  "blade verbatim": {
    "body": [
      "@verbatim",
      "{{ ${1:variable} }}",
      "@endverbatim"
    ],
    "description": "displaying JavaScript variables in a large portion of your template",
    "prefix": "b:verbatim"
  },
  "can": {
    "body": [
      "@can('${1:update}', ${2:\\$post})",
      "    $3",
      "@endcan"
    ],
    "description": "display a portion of the page only if the user is authorized to perform a given action.",
    "prefix": "b:can"
  },
  "can-elsecan": {
    "body": [
      "@can('${1:update}', ${2:\\$post})",
      "    $3",
      "@elsecan('create', App\\Models\\\\${4:Post}::class)",
      "    $5",
      "@endcan"
    ],
    "description": "display a portion of the page only if the user is authorized to perform a given action.",
    "prefix": "b:can-elsecan"
  },
  "canany": {
    "body": [
      "@canany(['update', 'view', 'delete'], ${1:\\$post})",
      "    $2",
      "@endcanany"
    ],
    "description": "display a portion of the page only if the user is authorized to perform a given action.",
    "prefix": "b:canany"
  },
  "canany-elsecanany": {
    "body": [
      "@canany(['update', 'view', 'delete'], ${1:\\$post})",
      "    $2",
      "@elsecanany(['create'], App\\Models\\\\${3:Post}::class)",
      "    $4",
      "@endcanany"
    ],
    "description": "display a portion of the page only if the user is authorized to perform a given action.",
    "prefix": "b:canany-elsecanany"
  },
  "cannot": {
    "body": [
      "@cannot('${1:update}', ${2:\\$post})",
      "    $3",
      "@endcannot"
    ],
    "description": "display a portion of the page only if the user is authorized to perform a given action.",
    "prefix": "b:cannot"
  },
  "cannot-elsecannot": {
    "body": [
      "@cannot('${1:update}', ${2:\\$post})",
      "    $3",
      "@elsecannot('create', App\\Models\\\\${5:Post}::class)",
      "    $6",
      "@endcannot"
    ],
    "description": "display a portion of the page only if the user is authorized to perform a given action.",
    "prefix": "b:cannot-elsecannot"
  },
  "checked": {
    "body": "@checked(${1:true})",
    "description": "This directive will echo checked if the provided condition evaluates to true (Laravel 9.x)",
    "prefix": "b:checked"
  },
  "class": {
    "body": "@class(['${1:p-4}', ${2:'font-bold' => true}])",
    "description": "conditionally compiles a CSS class string. (Laravel 8.51)",
    "prefix": "b:class"
  },
  "component": {
    "body": [
      "@component('$1')",
      "    $2",
      "@endcomponent"
    ],
    "description": "component",
    "prefix": "b:component"
  },
  "csrf": {
    "body": "@csrf",
    "description": "form csrf field",
    "prefix": "b:csrf"
  },
  "data_get:laravel": {
    "body": "data_get($1, '${2}')",
    "prefix": "data_get:laravel"
  },
  "dd": {
    "body": "@dd($1)",
    "description": "dump and die",
    "prefix": "b:dd"
  },
  "disabled": {
    "body": "@disabled(${1:true})",
    "description": "The @disabled directive may be used to indicate if a given element should be \"disabled\" (Laravel 9.x)",
    "prefix": "b:disabled"
  },
  "dump": {
    "body": "@dump($1)",
    "description": "dump",
    "prefix": "b:dump"
  },
  "each loop": {
    "body": "@each('${1:view.name}', ${2:\\$collection}, '${3:variable}', '${4:view.empty}')",
    "description": "@each loop",
    "prefix": "b:each"
  },
  "echo __ function": {
    "body": [
      "{{ __('${1}') }}"
    ],
    "description": "__ function echo",
    "prefix": "echo __"
  },
  "empty": {
    "body": [
      "@empty(${1:\\$record})",
      "    $2",
      "@endempty"
    ],
    "description": "empty",
    "prefix": "b:empty"
  },
  "env": {
    "body": [
      "@env('${1:staging}')",
      "    $2",
      "@endenv"
    ],
    "description": "env",
    "prefix": "b:env"
  },
  "error": {
    "body": [
      "@error('${1:record}')",
      "    $2",
      "@enderror"
    ],
    "description": "error",
    "prefix": "b:error"
  },
  "forelse-block": {
    "body": [
      "@forelse (${1:\\$collection} as ${2:\\$item})",
      "    $3",
      "@empty",
      "    $4",
      "@endforelse"
    ],
    "description": "@forelse block",
    "prefix": "b:forelse"
  },
  "guest": {
    "body": [
      "@guest",
      "    $1",
      "@endguest"
    ],
    "description": "guest",
    "prefix": "b:guest"
  },
  "includeFirst": {
    "body": "@includeFirst(['${1:view.name}', '${2:variable}'], [${3:'some' => 'data'}])",
    "description": "includeFirst",
    "prefix": "b:includeFirst"
  },
  "includeIf": {
    "body": "@includeIf('${1:view.name}'${2:, ['some' => 'data']})",
    "description": "include a view that may or may not be present, you should use the @includeIf directive",
    "prefix": "b:includeIf"
  },
  "includeUnless": {
    "body": "@includeUnless(${1:\\$boolean}, '${2:view.name}', [${3:'some' => 'data'}])",
    "description": "includeUnless",
    "prefix": "b:includeUnless"
  },
  "includeWhen": {
    "body": "@includeWhen(${1:\\$boolean}, '${2:view.name}', [${3:'some' => 'data'}])",
    "description": "includeWhen",
    "prefix": "b:includeWhen"
  },
  "inject service": {
    "body": "@inject('${1:name}', '${2:class}')",
    "description": "@inject Service",
    "prefix": "b:inject"
  },
  "isset": {
    "body": [
      "@isset(${1:\\$record})",
      "    $2",
      "@endisset"
    ],
    "description": "isset",
    "prefix": "b:isset"
  },
  "js": {
    "body": "@js(${1:\\$data})",
    "description": "This directive is useful to properly escape JSON within HTML quotes",
    "prefix": "b:js"
  },
  "label with lang": {
    "body": [
      ":label=\"__('$1')\""
    ],
    "prefix": "label"
  },
  "lang": {
    "body": "@lang('${1:messages.welcome}')",
    "description": "lang",
    "prefix": "b:lang"
  },
  "loop": {
    "body": [
      "\\$loop->${1:first}"
    ],
    "description": "$loop->(index|remaining|count|first|last|depth|parent)",
    "prefix": "b:loop"
  },
  "loop first": {
    "body": [
      "@if (\\$loop->first)",
      "    ${1:{{-- This is the first iteration --\\}\\}}",
      "@endif"
    ],
    "description": "$loop->first",
    "prefix": "b:loop-first"
  },
  "loop last": {
    "body": [
      "@if (\\$loop->last)",
      "    ${1:{{-- This is the last iteration --\\}\\}}",
      "@endif"
    ],
    "description": "$loop->last",
    "prefix": "b:loop-last"
  },
  "method": {
    "body": "@method($1)",
    "description": "form method field",
    "prefix": "b:method"
  },
  "once": {
    "body": [
      "@once",
      "    $1",
      "@endonce"
    ],
    "description": "define a portion of template that will only be evaluated once per rendering cycle",
    "prefix": "b:once"
  },
  "pageBreak": {
    "body": "{!! pageBreak() !!}",
    "prefix": "pageBreak"
  },
  "php": {
    "body": [
      "@php",
      "    $1",
      "@endphp"
    ],
    "description": "@php block code in view",
    "prefix": "b:php"
  },
  "prepend": {
    "body": [
      "@prepend('${1:scripts}')",
      "    $2",
      "@endprepend"
    ],
    "description": "prepend content to a stack",
    "prefix": "b:prepend"
  },
  "prependOnce": {
    "body": [
      "@prependOnce('${1:scripts}')",
      "    $2",
      "@endPrependOnce"
    ],
    "description": "Combine @once and @prepend for convenience (Laravel 9.x)",
    "prefix": "b:prependOnce"
  },
  "production": {
    "body": [
      "@production",
      "    $1",
      "@endproduction"
    ],
    "description": "production",
    "prefix": "b:production"
  },
  "props": {
    "body": "@props(['${1:propName}'])",
    "description": "Blade component data properties",
    "prefix": "b:props"
  },
  "pushIf": {
    "body": [
      "@pushIf(${1:\\$condition}, '${2:scripts}')",
      "    $3",
      "@endPushIf"
    ],
    "description": "Combine @if and @push for convenience",
    "prefix": "b:pushIf"
  },
  "pushOnce": {
    "body": [
      "@pushOnce('${1:scripts}')",
      "    $2",
      "@endPushOnce"
    ],
    "description": "Combine @once and @push for convenience (Laravel 9.x)",
    "prefix": "b:pushOnce"
  },
  "readonly": {
    "body": "@readonly(${1:true})",
    "description": "The @readonly directive may be used to indicate if a given element should be \"readonly\" (Laravel 9.x)",
    "prefix": "b:readonly"
  },
  "required": {
    "body": "@required(${1:true})",
    "description": "The @required directive may be used to indicate if a given element should be \"required\" (Laravel 9.x)",
    "prefix": "b:required"
  },
  "selected": {
    "body": "@selected(${1:true})",
    "description": "The @selected directive may be used to indicate if a given select option should be \"selected\" (Laravel 9.x)",
    "prefix": "b:selected"
  },
  "session": {
    "body": [
      "@session('${1:status}')",
      "    $2",
      "@endsession"
    ],
    "description": "The @session directive may be used to determine if a session value exists (Laravel 10.x)",
    "prefix": "b:session"
  },
  "si-pmn:ii>strong+p": {
    "body": [
      "<li>",
      "    <strong>${1:}</strong>",
      "    <p>${2:}</p>",
      "</li>"
    ],
    "prefix": "si-pmn:ii>strong+p"
  },
  "sip-pmn:li>div>span+p": {
    "body": [
      "<li>",
      "    <div>",
      "        <span>${1:}</span>",
      "        <p>${2:}</p>",
      "    </div>",
      "</li>"
    ],
    "prefix": "sip-pmn:li>div>span+p"
  },
  "sip-pmn:tabel-title": {
    "body": "<div align=\"center\" class=\"tabel-title\">${1:}</div>",
    "prefix": "sip-pmn:tabel-title"
  },
  "sip-pmn:tr>td>span+p": {
    "body": [
      "<tr>",
      "    <td valign=\"top\"><strong>${1:}</strong></td>",
      "    <td valign=\"top\">",
      "        <span><strong>${2:}</strong></span>",
      "        <p>${3:}</p>",
      "    </td>",
      "</tr>"
    ],
    "prefix": "sip-pmn:tr>td>span+p"
  },
  "slot": {
    "body": [
      "@slot('$1')",
      "    $2",
      "@endslot"
    ],
    "description": "slot",
    "prefix": "b:slot"
  },
  "style": {
    "body": "@style($1)",
    "description": "The @style directive may be used to conditionally add inline CSS styles to an HTML element (Laravel 9.x)",
    "prefix": "b:style"
  },
  "switch": {
    "body": [
      "@switch(${1:\\$type})",
      "    @case(${2:1})",
      "        $3",
      "        @break",
      "    @case(${4:2})",
      "        $5",
      "        @break",
      "    @default",
      "        $6",
      "@endswitch"
    ],
    "description": "switch",
    "prefix": "b:switch"
  },
  "try catch db:beginTransaction()": {
    "body": [
      "DB::beginTransaction();",
      "try {",
      "    ${1:}",
      "    DB::commit();",
      "} catch (\\Exception \\$e) {",
      "    Log::error($e);",
      "    DB::rollBack();",
      "}"
    ],
    "prefix": "try catch db:beginTransaction()"
  },
  "use": {
    "body": "@use('${1:App\\Models\\Flight}')",
    "description": "The @use directive may be used to import a class (Laravel 10.x)",
    "prefix": "b:use"
  },
  "use-alias": {
    "body": "@use('${1:App\\Models\\Flight}', '${2:FlightModel}')",
    "description": "The @use directive may be used to import a class as specified alias name (Laravel 10.x)",
    "prefix": "b:use-alias"
  },
  "while-block": {
    "body": [
      "@while ($1)",
      "    $2",
      "@endwhile"
    ],
    "description": "@while block",
    "prefix": "b:while"
  },
  "wire:model": {
    "body": [
      "wire:model=\"${1}\""
    ],
    "prefix": "wire:model"
  },
  "x-card:with-title": {
    "body": [
      "<x-card>",
      "    <x-title :title=\"__('${1}')\" :subtitle=\"__(${2})\" />",
      "</x-card>"
    ],
    "prefix": "x-card:with-title"
  },
  "x-card:with-title-and-subtoitle": {
    "body": [
      "<x-card>",
      "    <div class=\"text-sm font-semibold\">{{ __('${1}') }}</div>",
      "    <div class=\"text-xs font-normal text-gray-500 mt-1\">{{ __('${2}') }}</div>",
      "</x-card>"
    ],
    "prefix": "x-card:with-title-and-subtoitle"
  },
  "x-title": {
    "body": "<x-title :title=\"__('${1:}')\" :subtitle=\"__('${2:}')\"></x-title>",
    "prefix": "x-title"
  },
  "x-ui.card": {
    "body": [
      "<x-ui.card :title=\"__('${1:}')\">",
      "  ${2:}",
      "</x-ui.card>"
    ],
    "prefix": "x-ui.card"
  },
  "x-ui.text-entry": {
    "body": "<x-ui.text-entry :label=\"__('${1:}')\">${2:}</x-ui.text-entry>",
    "prefix": "x-ui.text-entry"
  }
